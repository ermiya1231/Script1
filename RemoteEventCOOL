-- ۶. کادرهای ورودی (The Triple Kaders)
local function createLuxuryKader(placeholder, posY)
    local box = Instance.new("TextBox", MainFrame)
    box.Size = UDim2.new(1, -50, 0, 42)
    box.Position = UDim2.new(0, 25, 0, posY)
    box.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.PlaceholderText = placeholder
    box.PlaceholderColor3 = Color3.fromRGB(90, 90, 100)
    box.Font = Enum.Font.Code
    box.TextSize = 14
    box.Text = ""
    box.ClearTextOnFocus = false
    
    local kCorner = Instance.new("UICorner", box)
    kCorner.CornerRadius = UDim.new(0, 6)
    
    local kStroke = Instance.new("UIStroke", box)
    kStroke.Thickness = 1
    kStroke.Color = Color3.fromRGB(40, 40, 45)
    
    -- افکت تغییر رنگ حاشیه هنگام کلیک روی کادر
    box.Focused:Connect(function() kStroke.Color = Color3.fromRGB(255, 255, 255) end)
    box.FocusLost:Connect(function() kStroke.Color = Color3.fromRGB(40, 40, 45) end)
    
    return box
end

local Kader1 = createLuxuryKader("Main Remote (e.g. game.RS.Remotes.Buy)", 65)
local Kader2 = createLuxuryKader("Secondary Remote (Optional)", 125)
local Kader3 = createLuxuryKader("Payload / Argument (e.g. Gold)", 185)

-- ۷. دکمه اصلی اجرای ریموت (Execute Button)
local ExecBtn = Instance.new("TextButton", MainFrame)
ExecBtn.Size = UDim2.new(1, -50, 0, 45)
ExecBtn.Position = UDim2.new(0, 25, 0, 255)
ExecBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 28)
ExecBtn.Text = "EXECUTE PAYLOAD"
ExecBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ExecBtn.Font = Enum.Font.GothamBold
ExecBtn.TextSize = 14

local btnCorner = Instance.new("UICorner", ExecBtn)
btnCorner.CornerRadius = UDim.new(0, 8)

local btnStroke = Instance.new("UIStroke", ExecBtn)
btnStroke.Thickness = 1
btnStroke.Color = Color3.fromRGB(60, 60, 65)

-- منطق کلیک دکمه و فایر کردن ریموت
ExecBtn.MouseButton1Click:Connect(function()
    if Kader1.Text ~= "" then
        -- ساخت افکت فلش زدن دکمه هنگام کلیک موفق
        ExecBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        task.delay(0.1, function() ExecBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 28) end)
        
        -- اجرای کد تزریق ریموت به صورت محافظت شده (pcall)
        local success, err = pcall(function()
            -- پیدا کردن مسیر ریموت اصلی بر اساس متنی که توی کادر ۱ نوشتی
            local targetRemote = loadstring("return " .. Kader1.Text)()
            
            if targetRemote and targetRemote:IsA("RemoteEvent") then
                -- فرستادن پیلود کادر ۳ به سرور
                targetRemote:FireServer(Kader3.Text)
                print("[COOL RM] Successfully fired primary remote with payload: " .. Kader3.Text)
            end
            
            -- اگر کادر دوم هم پر شده بود، آن را هم فایر کن
            if Kader2.Text ~= "" then
                local secondaryRemote = loadstring("return " .. Kader2.Text)()
                if secondaryRemote and secondaryRemote:IsA("RemoteEvent") then
                    secondaryRemote:FireServer(Kader3.Text)
                    print("[COOL RM] Successfully fired secondary remote.")
                end
            end
        end)
        
        if not success then
            warn("[COOL RM] Error executing remotes: " .. tostring(err))
        end
    else
        print("[COOL RM] Please enter a valid Main Remote path.")
    end
end)
