COOL_Ui.Name = "COOL_RemoteManager"
COOL_Ui.Parent = CoreGui
COOL_Ui.IgnoreGuiInset = true

-- پخش صدای کلاسیک روبلاکس هنگام باز شدن
local sound = Instance.new("Sound", game.Workspace)
sound.SoundId = "rbxassetid://12222242" -- Classic Oof
sound.Volume = 0.8
sound:Play()

-- ۲. پنل اصلی (Luxury Deep Black)
local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 420, 0, 340)
MainFrame.Position = UDim2.new(0.5, -210, 0.5, -170)
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 12) -- مشکی لوکس OLED
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Parent = COOL_Ui

local uiCorner = Instance.new("UICorner", MainFrame)
uiCorner.CornerRadius = UDim.new(0, 12)

-- ۳. حاشیه نئون متحرک (Dynamic RGB Border)
local uiStroke = Instance.new("UIStroke", MainFrame)
uiStroke.Thickness = 2
uiStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

task.spawn(function()
    while MainFrame.Parent do
        for i = 0, 1, 0.005 do
            uiStroke.Color = Color3.fromHSV(i, 0.85, 1)
            task.wait(0.02)
        end
    end
end)

-- ۴. سیستم درگ کردن و جابه‌جایی منو (Smooth Dragging)
local dragging, dragInput, dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

