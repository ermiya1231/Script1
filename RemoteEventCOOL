local function FireSelectedRemote()
    if CurrentRemote and CurrentArgs then
        if CurrentRemote:IsA("RemoteEvent") then
            CurrentRemote:FireServer(unpack(CurrentArgs))
        elseif CurrentRemote:IsA("RemoteFunction") then
            task.spawn(function()
                CurrentRemote:InvokeServer(unpack(CurrentArgs))
            end)
        end
    end
end

