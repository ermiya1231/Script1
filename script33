                -- ۳. تلپورت و فیکس کردن شیفت‌لاک بلافاصله پس از ریسپاون شدن کاراکتر جدید
                local characterAddedConn
                characterAddedConn = LocalPlayer.CharacterAdded:Connect(function(newChar)
                    local newRoot = newChar:WaitForChild("HumanoidRootPart", 5)
                    local newHumanoid = newChar:WaitForChild("Humanoid", 5)
                    
                    if newRoot and newHumanoid then
                        task.wait(0.15) -- صبر کوتاه برای پایداری کامل سیستم دوربین روبلاکس
                        
                        -- تلپورت به موقعیت قبلی
                        newRoot.CFrame = savedCFrame
                        
                        -- 🔒 فیکس کردن قطعی باگ شیفت‌لاک (Mouse Lock)
                        pcall(function()
                            local playerScripts = LocalPlayer:WaitForChild("PlayerScripts", 5)
                            if playerScripts then
                                local playerModule = require(playerScripts:WaitForChild("PlayerModule"))
                                if playerModule then
                                    local cameraModule = playerModule:GetCameras()
                                    if cameraModule and cameraModule.activeMouseLockController then
                                        local mouseLock = cameraModule.activeMouseLockController
                                        -- ریفرش کردن استیت شیفت‌لاک کلاینت برای همگام‌سازی مجدد با دوربین کاراکتر جدید
                                        if mouseLock:GetIsMouseLocked() then
                                            mouseLock:OnMouseLockToggled() -- خاموش کردن موقت
                                            task.wait(0.05)
                                            mouseLock:OnMouseLockToggled() -- روشن کردن مجدد برای قفل شدن روی مرکز صفحه
                                        end
                                    end
                                end
                            end
                        end)
                        
                        notify("Physics & ShiftLock Restored! ✅")
                    end
                    characterAddedConn:Disconnect()
                end)
            else
                notify("Error: Character not ready.")
            end
        end)
    end
end)

