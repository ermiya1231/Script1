-- Global Sound Object for playing music
local currentSound = workspace:FindFirstChild("LuxuryGUISound") or Instance.new("Sound", workspace)
currentSound.Name = "LuxuryGUISound"

-- Function to stop music
local function stopAllMusic()
    currentSound:Stop()
end

-- Function to play music
local function playMusic(id, pitch)
    currentSound:Stop()
    currentSound.SoundId = "rbxassetid://" .. tostring(id)
    currentSound.Pitch = pitch or 1
    currentSound.Volume = 2
    if not currentSound.IsLoaded then
        currentSound.Loaded:Wait()
    end
    currentSound:Play()
end

-- Function to create buttons (Luxury Style)
local function createButton(name, isStop, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -6, 0, 32)
    
    if isStop then
        btn.BackgroundColor3 = Color3.fromRGB(180, 40, 40) -- قرمز برای دکمه استاپ
        btn.BackgroundTransparency = 0.3
    else
        btn.BackgroundColor3 = Color3.fromRGB(60, 35, 100) -- بنفش دکمه‌ها
        btn.BackgroundTransparency = 0.5
    end
    
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = scroll

    local crn = Instance.new("UICorner")
    crn.CornerRadius = UDim.new(0, 8)
    crn.Parent = btn
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = isStop and Color3.fromRGB(255,100,100) or Color3.fromRGB(140, 80, 255)
    btnStroke.Thickness = 1
    btnStroke.Transparency = 0.7
    btnStroke.Parent = btn

    -- Hover Animations
    btn.MouseEnter:Connect(function()
        btn.BackgroundTransparency = isStop and 0.1 or 0.3
        btnStroke.Transparency = 0.3
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundTransparency = isStop and 0.3 or 0.5
        btnStroke.Transparency = 0.7
    end)

    btn.MouseButton1Click:Connect(callback)
end

