    if isActive then
        toggleButton.Text = "STATUS: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        toggleButton.TextColor3 = Color3.fromRGB(255, 255, 0)
        
        originalClockTime = Lighting.ClockTime
        originalOutdoorAmbient = Lighting.OutdoorAmbient
        
        startSoundLoop()
        
        if humanoid then
            humanoid.WalkSpeed = 150
        end
        
        lastStablePosition = humanoidRootPart.Position
        originalCFrame = humanoidRootPart.CFrame
        virtualTarget.Position = lastStablePosition
        
        camera.CameraSubject = virtualTarget
        cameraConnection = RunService.RenderStepped:Connect(syncVirtualTarget)
    else
        toggleButton.Text = "STATUS: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 5, 5)
        toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        stopSoundLoop()
        isNoclip = false
        noclipScreenText.TextTransparency = 1
        
        Lighting.ClockTime = originalClockTime
        Lighting.OutdoorAmbient = originalOutdoorAmbient
        
        if noclipConnection then noclipConnection:Disconnect() noclipConnection = nil end
        
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
        
        if humanoid then
            humanoid.WalkSpeed = 16
        end
        
        if humanoidRootPart and originalCFrame then
            humanoidRootPart.CFrame = originalCFrame
            humanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end
        
        if cameraConnection then
            cameraConnection:Disconnect()
            cameraConnection = nil
        end
        camera.CameraSubject = humanoid
    end
end)

