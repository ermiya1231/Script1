-- // سیستم نوتیفیکیشن خفن و لوکس //
local function showNotification(message)
    -- ساخت فریم نوتیفیکیشن
    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 200, 0, 50)
    -- شروع موقعیت از بیرون صفحه برای افکت انیمیشن ورود
    notifFrame.Position = UDim2.new(1, 10, 0.85, 0)
    notifFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    notifFrame.BorderSizePixel = 0
    notifFrame.Parent = screenGui

    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 8)
    notifCorner.Parent = notifFrame

    local notifStroke = Instance.new("UIStroke")
    notifStroke.Color = Color3.fromRGB(255, 230, 0)
    notifStroke.Thickness = 1.5
    notifStroke.Parent = notifFrame

    local notifText = Instance.new("TextLabel")
    notifText.Size = UDim2.new(1, 0, 1, 0)
    notifText.BackgroundTransparency = 1
    notifText.Text = message
    notifText.TextColor3 = Color3.fromRGB(255, 255, 255)
    notifText.TextSize = 13
    notifText.Font = Enum.Font.GothamBold
    notifText.Parent = notifFrame

    -- انیمیشن ورود از سمت راست به داخل صفحه
    local tweenIn = TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.82, 0, 0.85, 0)
    })
    tweenIn:Play()

    -- حذف خودکار و انیمیشن خروج بعد از ۲ ثانیه
    task.spawn(function()
        task.wait(2)
        local tweenOut = TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 10, 0.85, 0)
        })
        tweenOut:Play()
        tweenOut.Completed:Connect(function()
            notifFrame:Destroy()
        end)
    end)
end

-- // مدیریت لایه‌های صوتی ترکیبی دوتایی با شرط حرکت //
local soundThread = nil

local function stopSoundLoop()
    if soundThread then
        task.cancel(soundThread)
        soundThread = nil
    end
    for _, obj in pairs(workspace:GetChildren()) do
        if obj.Name == "ReverseFlashMusic" or obj.Name == "ReverseFlashMusic2" then
            obj:Destroy()
        end
    end
end

local function startSoundLoop()
    stopSoundLoop() 
    soundThread = task.spawn(function()
        while isActive do
            local flashSound1 = Instance.new("Sound")
            flashSound1.Name = "ReverseFlashMusic"
            flashSound1.SoundId = "rbxassetid://89362634813966"
            flashSound1.Volume = 4
            flashSound1.PlaybackSpeed = 1
            flashSound1.Looped = false
            flashSound1.Parent = workspace
            flashSound1:Play()
            flashSound1.Ended:Connect(function() flashSound1:Destroy() end)
            
            if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                local flashSound2 = Instance.new("Sound")
                flashSound2.Name = "ReverseFlashMusic2"
                flashSound2.SoundId = "rbxassetid://128695660714222"
                flashSound2.Volume = 1.7
                flashSound2.PlaybackSpeed = 1.2
                flashSound2.Looped = false
                flashSound2.Parent = workspace
                flashSound2:Play()
                flashSound2.Ended:Connect(function() flashSound2:Destroy() end)
            end
            
            task.wait(0.5)
        end
    end)
end

-- // منطق رگباری اتوماتیک تله‌پورت //
task.spawn(function()
    while true do
        task.wait(0.01) 
        
        if isActive and character and humanoidRootPart and humanoid then
            local currentCFrame = humanoidRootPart.CFrame
            
            if currentCFrame.Y < (SKY_HEIGHT - 300) then
                lastStablePosition = currentCFrame.Position
                originalCFrame = currentCFrame
            end
            
            local savedAssemblyVelocity = humanoidRootPart.AssemblyLinearVelocity
            local savedAssemblyAngularVelocity = humanoidRootPart.AssemblyAngularVelocity
            
            local skyCFrame = originalCFrame + Vector3.new(0, SKY_HEIGHT, 0)
            
            humanoidRootPart.CFrame = skyCFrame
            task.wait(0.001) 
            
            if isActive and humanoidRootPart and originalCFrame then
                humanoidRootPart.CFrame = originalCFrame
                humanoidRootPart.AssemblyLinearVelocity = savedAssemblyVelocity
                humanoidRootPart.AssemblyAngularVelocity = savedAssemblyAngularVelocity
            end
        end
    end
end)

-- // مدیریت پارت مجازی دوربین //
local function syncVirtualTarget()
    if isActive and humanoidRootPart then
        virtualTarget.Position = virtualTarget.Position:Lerp(lastStablePosition, 0.25)
    end
end

-- // سیستم ردیابی دکمه‌های Q و E کیبورد برای سرعت //
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- اگر بازیکن در حال چت کردن در بازی نباشد اسکریپت کلیدها را کار می‌اندازد
    if gameProcessed then return end
    if not isActive or not humanoid then return end

    if input.KeyCode == Enum.KeyCode.E then
        -- افزایش سرعت به اندازه ۱۰ واحد
        humanoid.WalkSpeed = humanoid.WalkSpeed + 10
        showNotification("⚡ SPEED INCREASED: " .. tostring(humanoid.WalkSpeed))
    elseif input.KeyCode == Enum.KeyCode.Q then
        -- کاهش سرعت به اندازه ۱۰ واحد (حداقل سرعت روی ۱۶ قفل می‌ماند تا چیت خراب نشود)
        if humanoid.WalkSpeed > 16 then
            humanoid.WalkSpeed = math.max(16, humanoid.WalkSpeed - 10)
            showNotification("⚠️ SPEED DECREASED: " .. tostring(humanoid.WalkSpeed))
        end
    end
end)

-- // مدیریت دکمه و وضعیت همراه با فرود امن روی زمین //
toggleButton.MouseButton1Click:Connect(function()
    isActive = not isActive
    
    if isActive then
        toggleButton.Text = "STATUS: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        toggleButton.TextColor3 = Color3.fromRGB(255, 255, 0)
        
        startSoundLoop()
        
        if humanoid then
            humanoid.WalkSpeed = 150
        end
        
        lastStablePosition = humanoidRootPart.Position
        originalCFrame = humanoidRootPart.CFrame
        virtualTarget.Position = lastStablePosition
        
        camera.CameraSubject = virtualTarget
        cameraConnection = RunService.RenderStepped:Connect(syncVirtualTarget)
    else
        toggleButton.Text = "STATUS: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 5, 5)
        toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        stopSoundLoop()
        
        if humanoid then
            humanoid.WalkSpeed = 16
        end
        
        if humanoidRootPart and originalCFrame then
            humanoidRootPart.CFrame = originalCFrame
            humanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end
        
        if cameraConnection then
            cameraConnection:Disconnect()
            cameraConnection = nil
        end
        camera.CameraSubject = humanoid
    end
end)

-- بازنشانی پارت‌ها در صورت ریسپاون یا مرگ
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    
    if isActive then
        stopSoundLoop()
        if cameraConnection then
            cameraConnection:Disconnect()
            cameraConnection = nil
        end
        camera.CameraSubject = humanoid
        isActive = false
        toggleButton.Text = "STATUS: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 5, 5)
        toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end)
