-- // سیستم نوتیفیکیشن هوشمند ضد اسپم //
local currentNotifFrame = nil
local currentNotifText = nil
local notifThread = nil

local function showNotification(message)
    if currentNotifFrame and currentNotifText then
        currentNotifText.Text = message
        if notifThread then task.cancel(notifThread) end
        
        notifThread = task.spawn(function()
            task.wait(2)
            local tweenOut = TweenService:Create(currentNotifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 10, 0.85, 0)
            })
            tweenOut:Play()
            tweenOut.Completed:Connect(function()
                if currentNotifFrame then currentNotifFrame:Destroy() end
                currentNotifFrame = nil
                currentNotifText = nil
            end)
        end)
        return
    end

    currentNotifFrame = Instance.new("Frame")
    currentNotifFrame.Size = UDim2.new(0, 200, 0, 50)
    currentNotifFrame.Position = UDim2.new(1, 10, 0.85, 0)
    currentNotifFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    currentNotifFrame.BorderSizePixel = 0
    currentNotifFrame.Parent = screenGui

    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 8)
    notifCorner.Parent = currentNotifFrame

    local notifStroke = Instance.new("UIStroke")
    notifStroke.Color = Color3.fromRGB(255, 230, 0)
    notifStroke.Thickness = 1.5
    notifStroke.Parent = currentNotifFrame

    currentNotifText = Instance.new("TextLabel")
    currentNotifText.Size = UDim2.new(1, 0, 1, 0)
    currentNotifText.BackgroundTransparency = 1
    currentNotifText.Text = message
    currentNotifText.TextColor3 = Color3.fromRGB(255, 255, 255)
    currentNotifText.TextSize = 13
    currentNotifText.Font = Enum.Font.GothamBold
    currentNotifText.Parent = currentNotifFrame

    local tweenIn = TweenService:Create(currentNotifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.82, 0, 0.85, 0)
    })
    tweenIn:Play()

    notifThread = task.spawn(function()
        task.wait(2)
        local tweenOut = TweenService:Create(currentNotifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 10, 0.85, 0)
        })
        tweenOut:Play()
        tweenOut.Completed:Connect(function()
            if currentNotifFrame then currentNotifFrame:Destroy() end
            currentNotifFrame = nil
            currentNotifText = nil
        end)
    end)
end

-- // مدیریت لایه‌های صوتی ترکیبی دوتایی با شرط حرکت //
local soundThread = nil

local function stopSoundLoop()
    if soundThread then
        task.cancel(soundThread)
        soundThread = nil
    end
    for _, obj in pairs(workspace:GetChildren()) do
        if obj.Name == "ReverseFlashMusic" or obj.Name == "ReverseFlashMusic2" then
            obj:Destroy()
        end
    end
end

local function startSoundLoop()
    stopSoundLoop() 
    soundThread = task.spawn(function()
        while isActive do
            -- صداهای خود فلش معکوس هرگز نباید اسلو موشن یا 0.01 شوند
            local currentSpeed1 = 1
            local currentSpeed2 = 1.2

            local flashSound1 = Instance.new("Sound")
            flashSound1.Name = "ReverseFlashMusic"
            flashSound1.SoundId = "rbxassetid://89362634813966"
            flashSound1.Volume = 4
            flashSound1.PlaybackSpeed = currentSpeed1
            flashSound1.Looped = false
            flashSound1.Parent = workspace
            flashSound1:Play()
            flashSound1.Ended:Connect(function() flashSound1:Destroy() end)
            
            if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                local flashSound2 = Instance.new("Sound")
                flashSound2.Name = "ReverseFlashMusic2"
                flashSound2.SoundId = "rbxassetid://128695660714222"
                flashSound2.Volume = 1.7
                flashSound2.PlaybackSpeed = currentSpeed2
                flashSound2.Looped = false
                flashSound2.Parent = workspace
                flashSound2:Play()
                flashSound2.Ended:Connect(function() flashSound2:Destroy() end)
            end
            
            task.wait(0.5)
        end
    end)
end

-- // منطق رگباری اتوماتیک تله‌پورت //
task.spawn(function()
    while true do
        task.wait(0.01) 
        
        if isActive and character and humanoidRootPart and humanoid then
            local currentCFrame = humanoidRootPart.CFrame
            
            if currentCFrame.Y < (SKY_HEIGHT - 300) then
                lastStablePosition = currentCFrame.Position
                originalCFrame = currentCFrame
            end
            
            local savedAssemblyVelocity = humanoidRootPart.AssemblyLinearVelocity
            local savedAssemblyAngularVelocity = humanoidRootPart.AssemblyAngularVelocity
            
            local skyCFrame = originalCFrame + Vector3.new(0, SKY_HEIGHT, 0)
            
            humanoidRootPart.CFrame = skyCFrame
            task.wait(0.001) 
            
            if isActive and humanoidRootPart and originalCFrame then
                humanoidRootPart.CFrame = originalCFrame
                humanoidRootPart.AssemblyLinearVelocity = savedAssemblyVelocity
                humanoidRootPart.AssemblyAngularVelocity = savedAssemblyAngularVelocity
            end
        end
    end
end)

-- // مدیریت پارت مجازی دوربین //
local function syncVirtualTarget()
    if isActive and humanoidRootPart then
        virtualTarget.Position = virtualTarget.Position:Lerp(lastStablePosition, 0.25)
    end
end

-- // سیستم ردیابی کلیدهای Q, E و کلید R (نوکلیپ آنی و اسکن فوق عمیق 0.01) //
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not isActive or not humanoid then return end

    if input.KeyCode == Enum.KeyCode.E then
        if not isNoclip then
            humanoid.WalkSpeed = humanoid.WalkSpeed + 10
            showNotification("⚡ SPEED: " .. tostring(humanoid.WalkSpeed))
        else
            savedSpeedBeforeNoclip = savedSpeedBeforeNoclip + 10
            showNotification("⚡ SPEED (QUEUED): " .. tostring(savedSpeedBeforeNoclip))
        end
    elseif input.KeyCode == Enum.KeyCode.Q then
        if not isNoclip then
            if humanoid.WalkSpeed > 16 then
                humanoid.WalkSpeed = math.max(16, humanoid.WalkSpeed - 10)
                showNotification("⚠️ SPEED: " .. tostring(humanoid.WalkSpeed))
            end
        else
            if savedSpeedBeforeNoclip > 16 then
                savedSpeedBeforeNoclip = math.max(16, savedSpeedBeforeNoclip - 10)
                showNotification("⚠️ SPEED (QUEUED): " .. tostring(savedSpeedBeforeNoclip))
            end
        end
    
    -- فعالسازی NOCLIP فوری و اسکن عمیق صوتی با دکمه R
    elseif input.KeyCode == Enum.KeyCode.R then
        isNoclip = true
        noclipScreenText.TextTransparency = 0.8
        
        savedSpeedBeforeNoclip = humanoid.WalkSpeed
        humanoid.WalkSpeed = 20
        
        Lighting.ClockTime = 0 
        Lighting.OutdoorAmbient = Color3.fromRGB(10, 10, 10)

        -- اسکن کل محیط بازی و اعمال تغییر Pitch روی 0.01 به جز صدای کاراکتر شما
        table.clear(originalPitches)
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Sound") then
                if obj.Name ~= "ReverseFlashMusic" and obj.Name ~= "ReverseFlashMusic2" then
                    originalPitches[obj] = obj.PlaybackSpeed -- ذخیره مقدار قبلی برای بازگردانی دقیق
                    obj.PlaybackSpeed = 0.01
                end
            end
        end

        -- لوپ فریم به فریم نوکلیپ آنی بدون باگ فیزیکی
        if noclipConnection then noclipConnection:Disconnect() end
        noclipConnection = RunService.Stepped:Connect(function()
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if not isActive then return end
    
    -- غیرفعال کردن آنی حالت NOCLIP و بازگشت ۱۰۰٪ سریع فیزیک دیوارها
    if input.KeyCode == Enum.KeyCode.R then
        isNoclip = false
        noclipScreenText.TextTransparency = 1 
        
        if humanoid then
            humanoid.WalkSpeed = savedSpeedBeforeNoclip
        end
        
        Lighting.ClockTime = originalClockTime
        Lighting.OutdoorAmbient = originalOutdoorAmbient

        -- قطع فوری لوپ و بازگردانی فیزیک تصادم کلیدها به حالت پیش‌فرض بصورت آنی
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        
        -- اعمال اجباری و لحظه‌ای CanCollide به فیزیک بدنه پارت‌ها برای جلوگیری از سقوط یا تأخیر
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
        
        -- برگرداندن پیتچ تمام صداهای مپ به مقادیر کاملاً اصلی‌شان قبل از اسلو موشن
        for obj, originalPitch in pairs(originalPitches) do
            if obj and obj.Parent then
                obj.PlaybackSpeed = originalPitch
            end
        end
        table.clear(originalPitches)
    end
end)

-- // مدیریت دکمه و وضعیت همراه با فرود امن روی زمین //
