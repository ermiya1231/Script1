-- // تنظیمات افکت و دوربین مجازی //
local isActive = false
local SKY_HEIGHT = 2000 
local cameraConnection = nil
local lastStablePosition = Vector3.new()
local originalCFrame = nil 

-- ساخت پارت مجازی روی زمین (مخصوص قفل کردن دوربین روی آن)
