local MyTargetID = "122714132204276"
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

---------------------------------------------------------
-- 1. پیدا کردن هوشمند ابزار F3X
---------------------------------------------------------
local tool
for _, v in ipairs(Player:GetDescendants()) do
    if v.Name == "SyncAPI" then tool = v.Parent break end
end
if not tool then
    for _, v in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
        if v.Name == "SyncAPI" then tool = v.Parent break end
    end
end

if not tool or not tool:FindFirstChild("SyncAPI") then
    warn("ابزار F3X پیدا نشد!")
    return
end

local remote = tool.SyncAPI.ServerEndpoint

-- تابع ارسال دستورات به سرور F3X
local function SendF3X(args)
    return remote:InvokeServer(unpack(args))
end

---------------------------------------------------------
-- 2. موتور اصلی DECAL SPAM روی 6 وجه
---------------------------------------------------------
local function RunDecalSpam(id)
    local descendants = workspace:GetDescendants()
    
    local allFaces = {
        Enum.NormalId.Front,
        Enum.NormalId.Back,
        Enum.NormalId.Top,
        Enum.NormalId.Bottom,
        Enum.NormalId.Left,
        Enum.NormalId.Right
    }
    
    for i = 1, #descendants do
        local v = descendants[i]
        
        -- فیلتر کردن پارت‌ها و نادیده گرفتن اسکای‌باکس
        if v:IsA("BasePart") and v.Name ~= "CustomSkybox" and v.Name ~= "Skybox" then
            -- باز کردن قفل پارت در صورت قفل بودن
            SendF3X({"SetLocked", {v}, false})
            
            task.spawn(function()
                for j = 1, #allFaces do
                    local currentFace = allFaces[j]
                    -- ایجاد دکال و اعمال آیدی عکس به صورت همزمان
                    SendF3X({"CreateTextures", {{Part = v, Face = currentFace, TextureType = "Decal"}}})
                    SendF3X({"SyncTexture", {{Part = v, Face = currentFace, TextureType = "Decal", Texture = "rbxassetid://" .. id}}})
                end
            end)
        end
    end
end

---------------------------------------------------------
-- 3. اجرای مستقیم اسپم
---------------------------------------------------------
RunDecalSpam(MyTargetID)
print("Decal Spam باموفقیت روی تمامی پارت ها اعمال شد!")
